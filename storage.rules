rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email != null
          && (
            request.auth.token.email == 'rashyslop@outlook.com' ||
            request.auth.token.email == 'rashon_hyslop@outlook.com'
          );
    }

    match /audio/{fileName} {
      allow read:  if true;
      allow write: if isAdmin()
                   && request.resource.size < 100 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    match /video/{fileName} {
      allow read:  if true;
      allow write: if isAdmin()
                   && request.resource.size < 500 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }

    match /radio_media/{type}/{fileName} {
      allow read:  if true;
      allow write: if isAdmin()
                   && request.resource.size < 500 * 1024 * 1024;
    }

    match /profiles/{profileId}/{fileName} {
      allow read:  if true;
      allow write: if isAdmin()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
